{
  "name": "@kitware/vtk-wasm",
  "version": "0.0.0",
  "description": "A WebAssembly port of the VTK library",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kitware/vtk-wasm.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:debug": "vite build --sourcemap -m dev",
    "build:esm": "vite build",
    "build:viewer": "vite build -c vite.config.viewer.js",
    "build:vtk": "vite build -c vite.config.standalone.js",
    "build": "npm run build:esm && npm run build:vtk && npm run build:viewer",
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "docs:preview": "vitepress preview docs",
    "format": "prettier .  --write",
    "lint": "eslint --fix src",
    "clean": "rimraf dist",
    "semantic-release": "semantic-release"
  },
  "dependencies": {
    "jszip": "3.10.1"
  },
  "devDependencies": {
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "prettier": "3.5.3",
    "rimraf": "^6.0.1",
    "semantic-release": "24.2.7",
    "vite": "^6.2.4",
    "vitepress": "^1.6.3"
  },
  "files": [
    "dist/**/*"
  ],
  "exports": {
    "./remote": "./dist/esm/remote.mjs",
    "./vtk": "./dist/esm/vtk.mjs",
    "./viewer": "./dist/esm/viewer.mjs",
    "./viewer-umd.js": "./dist/umd/viewer.umd.js",
    "./vtk-umd.js": "./dist/umd/vtk.umd.js",
    "./viewer.css": "./dist/umd/viewer.css"
  }
}
