{
  "name": "@kitware/vtk-wasm",
  "version": "0.0.0",
  "description": "A WebAssembly port of the VTK library",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kitware/vtk-wasm.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:debug": "vite build --sourcemap -m dev",
    "build:esm": "vite build",
    "build:viewer": "vite build -c vite.config.viewer.js",
    "build:vtk": "vite build -c vite.config.standalone.js",
    "build": "npm run build:esm && npm run build:vtk && npm run build:viewer",
    "build:example:simple-app": "npm install --no-save --prefix examples/js/simple-app && npm run build --prefix examples/js/simple-app",
    "build:examples": "npm run build:example:simple-app",
    "docs:build": "npm run build && npm run build:examples && vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "docs:clean": "rimraf docs/.vitepress/dist",
    "docs:preview": "vitepress preview docs",
    "format": "prettier .  --write",
    "lint": "eslint --fix src",
    "clean": "rimraf dist",
    "semantic-release": "semantic-release"
  },
  "dependencies": {
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "codemirror": "^6.0.2",
    "js-untar": "^2.0.0",
    "jszip": "3.10.1"
  },
  "devDependencies": {
    "conventional-changelog-conventionalcommits": "9.1.0",
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "prettier": "3.5.3",
    "rimraf": "^6.0.1",
    "semantic-release": "25.0.2",
    "vite": "^6.2.4",
    "vitepress": "^1.6.3"
  },
  "files": [
    "dist/**/*"
  ],
  "exports": {
    "./style.css": "./dist/esm/vtk-wasm.css",
    "./remote": "./dist/esm/remote.mjs",
    "./vtk": "./dist/esm/vtk.mjs",
    "./viewer": "./dist/esm/viewer.mjs",
    "./viewer-umd.js": "./dist/umd/viewer.umd.js",
    "./vtk-umd.js": "./dist/umd/vtk.umd.js",
    "./viewer.css": "./dist/umd/viewer.css",
    "./umd/*": "./dist/umd/*",
    "./esm/*": "./dist/esm/*"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "preset": "conventionalcommits"
        }
      ],
      "@semantic-release/release-notes-generator",
      "@semantic-release/npm",
      [
        "@semantic-release/github",
        {
          "successCommentCondition": "<% return branch.name === 'main'; %>"
        }
      ]
    ]
  }
}
